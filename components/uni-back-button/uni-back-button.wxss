.uni-back-button {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.uni-back-button.dark {
  background-color: #1a1a1a;
  border-bottom: 1rpx solid #333;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.back-btn:active {
  background-color: #e0e0e0;
  transform: scale(0.95);
}

.uni-back-button.dark .back-btn {
  background-color: #333;
}

.uni-back-button.dark .back-btn:active {
  background-color: #444;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.uni-back-button.dark .back-icon {
  color: #fff;
}

.page-title {
  flex: 1;
  margin-left: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.uni-back-button.dark .page-title {
  color: #fff;
}
