/* components/calendar-picker/calendar-picker.wxss */
.calendar-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.calendar-container {
  width: 650rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
}

.month-navigation {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-button {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
}

.nav-button:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.95);
}

.arrow {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.current-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  min-width: 200rpx;
  text-align: center;
}

.close-button {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
}

.close-button:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.95);
}

.calendar-body {
  padding: 24rpx;
}

.weekdays {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.weekday {
  width: 14.28%;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
  padding-top: 8rpx;
}

.day-cell {
  width: 14.28%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.day-content {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  color: #333;
  position: relative;
  transition: all 0.2s ease;
}

.day-content:active {
  transform: scale(0.9);
}

.day-content.today {
  color: #4CAF50;
  font-weight: 600;
  border: 2rpx solid #4CAF50;
}

.day-content.selected {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.day-content.disabled {
  color: #ccc;
  background-color: transparent;
}

.day-content.disabled:active {
  transform: none;
}

.record-dot {
  position: absolute;
  bottom: 8rpx;
  width: 8rpx;
  height: 8rpx;
  background-color: #FFC107;
  border-radius: 50%;
}

.day-content.selected .record-dot {
  background-color: #fff;
}

.calendar-footer {
  display: flex;
  border-top: 2rpx solid #f0f0f0;
}

.footer-button {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.footer-button.cancel {
  color: #666;
  border-right: 2rpx solid #f0f0f0;
}

.footer-button.cancel:active {
  background-color: #f5f5f5;
}

.footer-button.confirm {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
}

.footer-button.confirm:active {
  opacity: 0.8;
}
