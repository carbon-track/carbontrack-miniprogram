/* components/image-uploader/image-uploader.wxss */

.uploader-container {
  padding: 30rpx;
}

.upload-area {
  width: 100%;
  height: 400rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  transition: all 0.3s ease;
}

.upload-area:active {
  background: #f5f5f5;
  transform: scale(0.98);
}

.icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.tip {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.sub-tip {
  font-size: 24rpx;
  color: #999;
}

.preview-area {
  position: relative;
}

.preview-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.image-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.primary {
  background: #07c160;
  color: white;
}

.status-panel {
  margin-top: 30rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f7f7f7;
  animation: fadeIn 0.3s ease;
}

.status-loading, .status-success, .status-error {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.loading-icon, .status-icon {
  margin-right: 20rpx;
  font-size: 40rpx;
}

.status-success {
  color: #07c160;
  background: #e8f8f0;
}

.status-error {
  color: #fa5151;
  background: #fee;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 深色模式 */
.uploader-container.dark .upload-area {
  border-color: #444;
  background: #2a2a2a;
}

.uploader-container.dark .upload-area:active {
  background: #333;
}

.uploader-container.dark .tip {
  color: #e0e0e0;
}

.uploader-container.dark .sub-tip {
  color: #999;
}

.uploader-container.dark .action-btn {
  background: #3a3a3a;
  color: #e0e0e0;
}

.uploader-container.dark .action-btn.primary {
  background: #07c160;
  color: white;
}

.uploader-container.dark .status-panel {
  background: #2a2a2a;
}

.uploader-container.dark .status-success {
  background: #0a2a1a;
  color: #07c160;
}

.uploader-container.dark .status-error {
  background: #2a0a0a;
  color: #ff6b6b;
}