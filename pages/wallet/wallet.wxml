<!--pages/wallet/wallet.wxml-->
<view class="container {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 返回按钮 -->
  <uni-back-button title="carbontrack" theme="{{theme}}" />
  <!-- 钱包卡片 -->
  <view class="wallet-card">
    <view class="balance-section">
      <text class="balance-label">💰 当前余额</text>
      <text class="balance-amount">{{balance}} ⭐</text>
      <button class="exchange-btn" bindtap="goToExchange" type="primary">
        🎁 去兑换
      </button>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-container">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="{{item.key}}"
    >
      <text class="tab-text">{{item.key === 'income' ? '💰 ' : '💸 '}}{{item.name}}</text>
    </view>
  </view>

  <!-- 交易记录列表 -->
  <view class="transactions-list">
    <view class="section-header">
      <view class="section-icon">📊</view>
      <text class="section-title">交易记录</text>
    </view>
    <view
      wx:for="{{transactionList}}"
      wx:key="id"
      class="transaction-item {{item.type}}"
      bindtap="viewTransactionDetail"
      data-id="{{item.id}}"
    >
      <view class="transaction-icon" style="background: {{item.gradient}}">
        <text class="transaction-emoji">{{item.emoji}}</text>
      </view>
      
      <view class="transaction-content">
        <view class="transaction-header">
          <text class="transaction-title">{{item.title}}</text>
          <text class="transaction-amount {{item.type}}">
            {{item.formattedAmount}}
          </text>
        </view>
        
        <view class="transaction-footer">
          <text class="transaction-description">{{item.description}}</text>
          <text class="transaction-date">📅 {{item.date}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{isLoading && !isRefreshing}}" class="loading-state">
      <view class="loading-content">⏳</view>
      <text>正在获取交易记录...</text>
    </view>

    <!-- 下拉刷新状态 -->
    <view wx:if="{{isRefreshing}}" class="refreshing-state">
      <view class="loading-content">🔄</view>
      <text>正在刷新记录...</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!isLoading && !isRefreshing && transactionList.length === 0}}" class="empty-state">
      <view class="empty-emoji">📝</view>
      <text class="empty-text">暂无交易记录</text>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{!hasMore && filteredTransactions.length > 0}}" class="no-more">
      <text>没有更多记录了</text>
    </view>
  </view>
</view>