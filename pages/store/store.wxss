/* pages/store/store.wxss */

/* 主题变量 */
.container {
  --primary-color: #34C759;
  --background-color: #F2F2F7;
  --text-color: #000000;
  --border-color: #E5E5EA;
  --card-background: #FFFFFF;
  --secondary-text: #8E8E93;
  --price-color: #FF9500;
  
  padding-bottom: 40rpx;
  background-color: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.container.dark {
  --primary-color: #4ECDC4;
  --background-color: #1C1C1E;
  --text-color: #FFFFFF;
  --border-color: #38383A;
  --card-background: #2C2C2E;
  --secondary-text: #8E8E93;
  --price-color: #FFB700;
}

/* 用户积分信息 */
.points-info {
  padding: 30rpx;
}

.points-card {
  background-color: var(--primary-color);
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.points-card::after {
  content: '';
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 200rpx;
  height: 200rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.points-label {
  font-size: 28rpx;
  color: #FFFFFF;
  opacity: 0.9;
  margin-bottom: 8rpx;
  display: block;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.points-icon {
  width: 80rpx;
  height: 80rpx;
  position: absolute;
  right: 60rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 分类选择 */
.category-scroll {
  white-space: nowrap;
  margin: 20rpx 0;
  padding: 0 30rpx;
}

.category-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 20rpx;
  background-color: var(--card-background);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  transition: all 0.3s;
}

.category-item.active {
  background-color: var(--primary-color);
  color: #FFFFFF;
  border-color: var(--primary-color);
}

/* 商品列表 */
.products-container {
  padding: 0 30rpx;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid var(--border-color);
  transition: transform 0.3s;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background-color: var(--background-color);
}

.product-image image {
  width: 100%;
  height: 100%;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-description {
  font-size: 24rpx;
  color: var(--secondary-text);
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  display: flex;
  align-items: center;
}

.price-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--price-color);
}

.stock-info {
  font-size: 22rpx;
  color: var(--secondary-text);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text,
.loading-more text,
.no-more text {
  font-size: 28rpx;
  color: var(--secondary-text);
}

.loading-more,
.no-more {
  text-align: center;
  padding: 40rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--secondary-text);
}