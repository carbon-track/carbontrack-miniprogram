/* pages/exchange/exchange.wxss */

.container {
  background-color: #F2F2F7;
  min-height: 100vh;
  box-sizing: border-box;
}

.container.dark {
  background-color: #1C1C1E;
}

/* 积分卡片 */
.points-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #4CAF50 0%, #2196F3 100%);
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.container.dark .points-card {
  background: linear-gradient(135deg, #009688 0%, #673AB7 100%);
}

.points-info {
  flex: 1;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 8rpx;
}

.points-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.points-detail-btn {
  background-color: rgba(255, 255, 255, 0.9);
  color: #34C759;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  border: none;
  outline: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.container.dark .points-detail-btn {
  background-color: rgba(255, 255, 255, 0.1);
  color: #4ECDC4;
}

.points-detail-btn:active {
  opacity: 0.9;
}

/* 分类标签 */
.category-tabs {
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #E5E5EA;
  margin-bottom: 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.container.dark .category-tabs {
  background-color: #2C2C2E;
  border-bottom: 1rpx solid #38383A;
}

.category-tabs scroll-view {
  white-space: nowrap;
  padding: 0 20rpx;
}

.category-tab {
  display: inline-block;
  padding: 24rpx 30rpx;
  margin-right: 10rpx;
  position: relative;
  font-size: 28rpx;
  color: #8E8E93;
}

.container.dark .category-tab {
  color: #8E8E93;
}

.category-tab.active {
  color: #34C759;
  font-weight: bold;
  background-color: rgba(52, 199, 89, 0.1);
  border-radius: 30rpx;
}

.container.dark .category-tab.active {
  color: #4ECDC4;
  background-color: rgba(78, 205, 196, 0.2);
}

.category-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 4rpx;
  background-color: #34C759;
}

.container.dark .category-tab.active::after {
  background-color: #4ECDC4;
}

/* 商品列表 */
.products-container {
  padding: 0 20rpx 20rpx 20rpx;
}

/* 区域标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000000;
}

.container.dark .section-title {
  color: #FFFFFF;
}

.product-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #E5E5EA;
  transition: transform 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.container.dark .product-item {
  background-color: #2C2C2E;
  border: 1rpx solid #38383A;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.product-item:active {
  transform: scale(0.98);
}

/* 商品图片 */
.product-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.product-emoji {
  font-size: 160rpx;
  color: white;
}

/* 商品内容 */
.product-content {
  flex: 1;
}

.product-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 10rpx;
  display: block;
}

.container.dark .product-name {
  color: #FFFFFF;
}

.product-description {
  font-size: 28rpx;
  color: #8E8E93;
  margin-bottom: 20rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 商品底部信息 */
.product-footer {
  border-top: 1rpx solid #E5E5EA;
  padding-top: 20rpx;
}

.container.dark .product-footer {
  border-top: 1rpx solid #38383A;
}

.product-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.product-points {
  font-size: 32rpx;
  font-weight: bold;
  color: #34C759;
}

.container.dark .product-points {
  color: #4ECDC4;
}

.points-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
}

.product-stock {
  font-size: 26rpx;
  color: #8E8E93;
}

.product-exchange {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.exchange-count {
  font-size: 24rpx;
  color: #8E8E93;
}

.exchange-btn {
  background: linear-gradient(135deg, #34C759 0%, #2196F3 100%);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  border: none;
  outline: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.container.dark .exchange-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #673AB7 100%);
}

.exchange-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.exchange-btn[disabled] {
  background-color: #E5E5EA;
  color: #8E8E93;
}

.container.dark .exchange-btn[disabled] {
  background-color: #38383A;
  color: #8E8E93;
}

/* 加载状态 */
.loading-state,
.refreshing-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-content {
  font-size: 60rpx;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text,
.refreshing-state text {
  font-size: 28rpx;
  color: #8E8E93;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-emoji {
  font-size: 160rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #8E8E93;
}