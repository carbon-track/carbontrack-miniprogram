/* pages/webview/webview.wxss */

/* 主题变量 */
.container {
  --primary-color: #34C759;
  --background-color: #F2F2F7;
  --text-color: #000000;
  --border-color: #E5E5EA;
  --card-background: #FFFFFF;
  --secondary-text: #8E8E93;
  
  background-color: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.container.dark {
  --primary-color: #4ECDC4;
  --background-color: #1C1C1E;
  --text-color: #FFFFFF;
  --border-color: #38383A;
  --card-background: #2C2C2E;
  --secondary-text: #8E8E93;
}

/* web-view组件 */
web-view {
  width: 100%;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--border-color);
  border-top: 6rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text {
  font-size: 32rpx;
  color: var(--secondary-text);
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  text-align: center;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.error-message {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 50rpx;
  line-height: 1.5;
  max-width: 80%;
}

.refresh-btn,
.close-btn {
  width: 60%;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 36rpx;
  margin-bottom: 20rpx;
}

.refresh-btn {
  background-color: var(--primary-color);
  color: white;
  border: none;
}

.close-btn {
  background-color: transparent;
  color: var(--text-color);
  border: 1rpx solid var(--border-color);
}