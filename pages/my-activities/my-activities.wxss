/* pages/my-activities/my-activities.wxss */

/* 主题变量 */
.container {
  --primary-color: #34C759;
  --background-color: #F2F2F7;
  --text-color: #000000;
  --border-color: #E5E5EA;
  --card-background: #FFFFFF;
  --secondary-text: #8E8E93;
  --success-color: #34C759;
  --ongoing-color: #4285F4;
  --completed-color: #34C759;
  
  background-color: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.container.dark {
  --primary-color: #4ECDC4;
  --background-color: #1C1C1E;
  --text-color: #FFFFFF;
  --border-color: #38383A;
  --card-background: #2C2C2E;
  --secondary-text: #8E8E93;
  --success-color: #4ECDC4;
  --ongoing-color: #5E97F6;
  --completed-color: #4ECDC4;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background-color: var(--card-background);
  border-bottom: 1rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  position: relative;
  font-size: 28rpx;
  color: var(--secondary-text);
}

.tab.active {
  color: var(--primary-color);
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background-color: var(--primary-color);
}

/* 活动列表 */
.activities-list {
  padding: 20rpx;
}

.activity-item {
  display: flex;
  background-color: var(--card-background);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
  transition: transform 0.2s;
}

.activity-item:active {
  transform: scale(0.98);
}

.activity-icon {
  width: 100rpx;
  height: 100rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.activity-icon image {
  width: 60rpx;
  height: 60rpx;
  filter: brightness(0) invert(1); /* 使图标变为白色 */
}

.activity-content {
  flex: 1;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  flex: 1;
}

.activity-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  margin-left: 20rpx;
}

.activity-item.ongoing .activity-status {
  background-color: var(--ongoing-color);
  color: white;
}

.activity-item.completed .activity-status {
  background-color: var(--completed-color);
  color: white;
}

.activity-description {
  font-size: 26rpx;
  color: var(--secondary-text);
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.activity-date {
  font-size: 24rpx;
  color: var(--secondary-text);
}

.activity-points {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary-color);
}

/* 进度条 */
.progress-bar-container {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background-color: var(--border-color);
  border-radius: 5rpx;
  overflow: hidden;
  margin-right: 15rpx;
}

.progress {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--secondary-text);
  min-width: 40rpx;
  text-align: right;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text {
  font-size: 28rpx;
  color: var(--secondary-text);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--secondary-text);
}