/* pages/carbon-history/carbon-history.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.container.dark {
  background-color: #1c1c1e;
}

/* 筛选器 */
.filter-section {
  padding: 30rpx;
  background-color: #fff;
}

.container.dark .filter-section {
  background-color: #2c2c2e;
}

.filter-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  color: #fff;
}

.filter-label {
  font-size: 32rpx;
  font-weight: 500;
}

.filter-arrow {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 统计信息 */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 20rpx 30rpx;
  padding: 40rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}

.container.dark .stat-label {
  color: #999;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container.dark .stat-value {
  color: #fff;
}

.stat-value.carbon-value {
  color: #34c759;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #e0e0e0;
}

/* 记录列表 */
.records-list {
  padding: 0 30rpx;
}

.record-item {
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-type {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
}

.type-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.container.dark .type-name {
  color: #fff;
}

.record-date {
  font-size: 26rpx;
  color: #999;
}

/* 记录内容 */
.record-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.record-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.container.dark .detail-text {
  color: #e0e0e0;
}

.detail-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.container.dark .detail-desc {
  color: #999;
}

.record-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.record-image image {
  width: 100%;
  height: 100%;
}

/* 记录底部 */
.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.record-stats {
  display: flex;
  gap: 16rpx;
}

.stat-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.stat-badge.carbon {
  background-color: rgba(52, 199, 89, 0.1);
  color: #34c759;
}

.stat-badge.points {
  background-color: rgba(255, 204, 0, 0.1);
  color: #ffcc00;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-weight: 500;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-state, .loading-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 60rpx 0;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.spinner-small {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .card {
  background-color: #2c2c2e;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}
