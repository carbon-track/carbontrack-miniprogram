<!--pages/carbon-history/carbon-history.wxml-->
<view class="container {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 返回按钮 -->
  <uni-back-button title="carbontrack" theme="{{theme}}" />
  <!-- 筛选器 -->
  <view class="filter-section">
    <picker mode="selector" range="{{filterOptions}}" range-key="name" bindchange="onFilterChange">
      <view class="filter-picker">
        <text class="filter-label">筛选：{{filterOptions[filter].name}}</text>
        <text class="filter-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section card">
    <view class="stat-item">
      <text class="stat-label">总记录数</text>
      <text class="stat-value">{{total}}</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-label">总碳减排</text>
      <text class="stat-value carbon-value">{{totalCarbon | toInteger}}kg</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-list">
    <view
      wx:for="{{records}}"
      wx:key="id"
      class="record-item card"
      bindtap="viewDetail"
      data-id="{{item.id}}"
      data-type="{{item.activityType}}"
      data-carbon="{{item.carbonValue}}"
      data-points="{{item.points}}"
    >
      <view class="record-header">
        <view class="record-type">
          <text class="type-icon">{{item.emoji}}</text>
          <text class="type-name">{{item.activityType}}</text>
        </view>
        <text class="record-date">{{item.formattedDate}}</text>
      </view>

      <view class="record-content">
     
        
        <view wx:if="{{item.imageUrl}}" class="record-image" bindtap="previewImage" data-url="{{item.imageUrl}}" catchtap="preventBubble">
          <image src="{{item.imageUrl}}" mode="aspectFill"></image>
        </view>
      </view>

      <view class="record-footer">
        <view class="record-stats">
          <view class="stat-badge carbon">
            <text class="badge-icon">🌱</text>
            <text class="badge-text">{{item.carbonValue | toInteger}}kg</text>
          </view>
          <view class="stat-badge points">
            <text class="badge-icon">⭐</text>
            <text class="badge-text">+{{item.points}}</text>
          </view>
        </view>
        <text class="record-time">{{item.formattedCreateTime}}</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loadingMore && !loading}}" class="loading-more">
      <view class="spinner-small"></view>
      <text>加载更多...</text>
    </view>

    <!-- 刷新状态 -->
    <view wx:if="{{refreshing}}" class="loading-state">
      <view class="spinner"></view>
      <text>刷新中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && !refreshing && records.length === 0}}" class="empty-state">
      <image src="/assets/icons/empty.png" mode="aspectFit" class="empty-icon"></image>
      <text class="empty-text">暂无记录</text>
      <text class="empty-hint">快去记录你的第一次环保行动吧！</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && records.length > 0 && !loading}}" class="no-more">
      <text>没有更多记录了</text>
    </view>
  </view>

  <!-- 记录详情弹窗 -->
  <record-detail-modal
    visible="{{showDetailModal}}"
    record="{{selectedRecord}}"
    bind:close="onCloseDetailModal"
  />
</view>
