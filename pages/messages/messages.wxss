/* pages/messages/messages.wxss */

/* 主题变量 */
.container {
  --primary-color: #34C759;
  --background-color: #F2F2F7;
  --text-color: #000000;
  --border-color: #E5E5EA;
  --card-background: #FFFFFF;
  --secondary-text: #8E8E93;
  --unread-indicator: #FF3B30;
  
  background-color: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.container.dark {
  --primary-color: #4ECDC4;
  --background-color: #1C1C1E;
  --text-color: #FFFFFF;
  --border-color: #38383A;
  --card-background: #2C2C2E;
  --secondary-text: #8E8E93;
  --unread-indicator: #FF453A;
}

/* 消息类型选择 */
.message-tabs {
  display: flex;
  background-color: var(--card-background);
  border-bottom: 1rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  position: relative;
  font-size: 28rpx;
  color: var(--secondary-text);
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background-color: var(--primary-color);
}

/* 操作栏 */
.action-bar {
  padding: 20rpx 30rpx;
  background-color: var(--card-background);
  border-bottom: 1rpx solid var(--border-color);
  display: flex;
  justify-content: flex-end;
}

.action-button {
  font-size: 28rpx;
  color: var(--primary-color);
}

/* 消息列表 */
.message-list {
  padding: 20rpx;
}

.message-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background-color: var(--card-background);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
  transition: transform 0.2s;
}

.message-item:active {
  transform: scale(0.98);
}

.message-item.unread {
  border-left: 6rpx solid var(--primary-color);
}

.message-left {
  flex: 1;
  margin-right: 20rpx;
}

.message-type {
  display: inline-block;
  padding: 4rpx 16rpx;
  background-color: var(--primary-color);
  color: white;
  font-size: 22rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.message-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 8rpx;
  display: block;
}

.message-content {
  font-size: 26rpx;
  color: var(--secondary-text);
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.message-time {
  font-size: 24rpx;
  color: var(--secondary-text);
  display: block;
}

.message-right {
  display: flex;
  align-items: center;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--unread-indicator);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text {
  font-size: 28rpx;
  color: var(--secondary-text);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--secondary-text);
}