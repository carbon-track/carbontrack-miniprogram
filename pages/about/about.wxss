  align-items: center;
  padding: 24rpx 20rpx;
  margin: 0 10rpx;
  border-radius: 12rpx;
  transition: background-color 0.2s;
}

.contact-item:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.container.dark .contact-item:active {
  background-color: rgba(255, 255, 255, 0.05);
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.contact-info {
  flex: 1;
}

.contact-label {
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 4rpx;
}

.contact-value {
  font-size: 24rpx;
  color: var(--secondary-text);
}

.arrow {
  font-size: 40rpx;
  color: var(--secondary-text);
}

/* 社交媒体网格 */
.social-grid {
  display: flex;
  padding: 0 30rpx 30rpx;
}

.social-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.social-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.social-name {
  font-size: 24rpx;
  color: var(--secondary-text);
}

/* 分享按钮 */
.share-section {
  padding: 30rpx;
}

.share-btn,
.share-moments-btn {
  width: 100%;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 36rpx;
  margin-bottom: 20rpx;
}

.share-btn {
  background-color: var(--primary-color);
  color: white;
  border: none;
}

.share-moments-btn {
  background-color: transparent;
  color: var(--text-color);
  border: 1rpx solid var(--border-color);
}

/* 版权信息 */
.copyright {
  text-align: center;
  padding: 20rpx;
}

.copyright text {
  font-size: 24rpx;
  color: var(--secondary-text);
}

/* 团队网格 */
.team-grid {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 20rpx 0;
}

.team-item {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f2ff 100%);
  border-radius: 24rpx;
  border-left: 6rpx solid #667eea;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.container.dark .team-item {
  background: linear-gradient(135deg, #2c2c2e 0%, #3a3a3c 100%);
  border-left: 6rpx solid #764ba2;
}

.team-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.3);
}

.avatar-emoji {
  font-size: 60rpx;
  color: white;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.team-info {
  flex: 1;
}

.team-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.container.dark .team-name {
  color: #ffffff;
}

.team-role {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.team-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
  margin-bottom: 20rpx;
}

.container.dark .team-desc {
  color: #cccccc;
}

.team-link {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 12rpx 0;
  cursor: pointer;
}

.link-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  margin-right: 10rpx;
}

.link-arrow {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
}

/* 使命列表 */
.mission-list {
  margin-top: 30rpx;
  padding: 0 20rpx;
}

.mission-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 25rpx;
  padding: 20rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 16rpx;
  border-left: 4rpx solid #667eea;
}

.container.dark .mission-item {
  background: rgba(102, 126, 234, 0.1);
}

.mission-dot {
  font-size: 40rpx;
  color: #667eea;
  margin-right: 20rpx;
  line-height: 1;
}

.mission-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 44rpx;
}

.container.dark .mission-text {
  color: #ffffff;
}

/* 成就网格 */
.achievements-grid {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 30rpx 0;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.15);
  position: relative;
  overflow: hidden;
}

.achievement-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.container.dark .achievement-item {
  background: linear-gradient(135deg, #2c2c2e 0%, #3a3a3c 100%);
}

.achievement-icon {
  font-size: 80rpx;
  margin-bottom: 25rpx;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.achievement-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 20rpx;
}

.achievement-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding: 20rpx 40rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 40rpx;
}

.container.dark .achievement-value {
  color: #ffffff;
  background: rgba(102, 126, 234, 0.2);
}

.achievement-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
}

.container.dark .achievement-desc {
  color: #cccccc;
}