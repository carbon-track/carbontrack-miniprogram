/* pages/forgot-password/forgot-password.wxss */

/* 主题变量 */
.container {
  --primary-color: #34C759;
  --background-color: #F2F2F7;
  --text-color: #000000;
  --border-color: #E5E5EA;
  --error-color: #FF3B30;
  --placeholder-color: #8E8E93;
  --button-background: #34C759;
  --button-text: #FFFFFF;
  --card-background: #FFFFFF;
  --secondary-button: #F2F2F7;
  
  padding: 40rpx 30rpx;
  background-color: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.container.dark {
  --primary-color: #4ECDC4;
  --background-color: #1C1C1E;
  --text-color: #FFFFFF;
  --border-color: #38383A;
  --error-color: #FF453A;
  --placeholder-color: #8E8E93;
  --button-background: #4ECDC4;
  --button-text: #FFFFFF;
  --card-background: #2C2C2E;
  --secondary-button: #38383A;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 20rpx;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-color);
  opacity: 0.7;
}

/* 消息容器样式 */
.error-message-container {
  background-color: rgba(255, 59, 48, 0.1);
  border: 1rpx solid var(--error-color);
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin: 20rpx 0;
}

.error-text {
  color: var(--error-color);
  font-size: 28rpx;
  line-height: 1.5;
}

.success-message-container {
  background-color: rgba(52, 199, 89, 0.1);
  border: 1rpx solid var(--primary-color);
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin: 20rpx 0;
}

.success-text {
  color: var(--primary-color);
  font-size: 28rpx;
  line-height: 1.5;
}

/* 表单样式 */
.reset-form {
  max-width: 600rpx;
  margin: 0 auto;
}

.form-group {
  margin-bottom: 30rpx;
}

.input-wrapper {
  background-color: var(--card-background);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  height: 100rpx;
  position: relative;
}

/* 表单输入样式优化 */
.input-wrapper input {
  padding: 0;
}

.input-wrapper input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: var(--text-color);
  background-color: transparent;
}

.input-wrapper .placeholder {
  color: var(--placeholder-color);
}

.error-message {
  font-size: 24rpx;
  color: var(--error-color);
  margin-top: 8rpx;
  display: block;
}

/* 按钮样式 */
.primary-button {
  background-color: var(--button-background);
  color: var(--button-text);
  font-size: 34rpx;
  font-weight: bold;
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.primary-button::after {
  border: none;
}



.action-buttons {
  margin-top: 40rpx;
}

.text-button {
  background-color: transparent;
  color: var(--text-color);
  font-size: 32rpx;
  margin-top: 20rpx;
}

.text-button::after {
  border: none;
}