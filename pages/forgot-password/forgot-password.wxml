<!--pages/forgot-password/forgot-password.wxml-->
<view class="container {{theme === 'dark' ? 'dark' : ''}}">
  <view class="header">
    <text class="title">找回密码</text>
    <text class="subtitle">请输入您注册时使用的邮箱，我们将发送重置密码的链接</text>
  </view>

  <form class="reset-form">
    <view class="form-group">
      <view class="input-wrapper">
        <input
          type="text"
          placeholder="邮箱地址"
          placeholder-class="placeholder"
          value="{{email}}"
          bindinput="onEmailInput"
        />
      </view>
      <text wx:if="{{emailError}}" class="error-message">{{emailError}}</text>
    </view>
    
    <!-- 错误消息 -->
    <view wx:if="{{errorMessage}}" class="error-message-container">
      <text class="error-text">{{errorMessage}}</text>
    </view>
    
    <!-- 成功消息 -->
    <view wx:if="{{successMessage}}" class="success-message-container">
      <text class="success-text">{{successMessage}}</text>
    </view>
    
    <button
      class="primary-button"
      type="primary"
      loading="{{isLoading}}"
      disabled="{{isLoading}}"
      bindtap="submitForgotPassword"
    >
      发送重置链接
    </button>

    <!-- 返回登录按钮 -->
    <view class="action-buttons">
      <button
        class="text-button"
        type="default"
        bindtap="goToLogin"
      >
        返回登录
      </button>
    </view>
  </form>
</view>